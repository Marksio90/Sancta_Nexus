# ============================================================
# Sancta Nexus — Zmienne środowiskowe
# Skopiuj ten plik do .env i uzupełnij wartości.
# NIGDY nie commituj pliku .env do repozytorium.
# ============================================================

# ----- Aplikacja -----
APP_NAME=Sancta Nexus
VERSION=1.0.0
DEBUG=false

# ----- Backend -----
BACKEND_PORT=8000

# ----- Frontend -----
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000
# VAPID public key — musi być identyczny z VAPID_PUBLIC_KEY w sekcji backend
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# ----- PostgreSQL -----
POSTGRES_USER=sancta
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=sancta_nexus
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://sancta:change-me-postgres-password@localhost:5432/sancta_nexus

# ----- Redis -----
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# ----- Qdrant (Vector Database — opcjonalne, RAG) -----
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# ----- Neo4j (Graph Database — opcjonalne, pamięć AI) -----
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me-neo4j-password
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
NEO4J_URI=bolt://localhost:7687

# ----- Uwierzytelnianie -----
SECRET_KEY=change-me-to-a-random-secret-key-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ----- LLM Provider -----
# Główny dostawca: "openai" lub "anthropic"
LLM_PROVIDER=openai
LLM_FALLBACK_PROVIDER=anthropic

# Modele OpenAI
LLM_PRIMARY_MODEL=gpt-4o
LLM_FAST_MODEL=gpt-4o-mini
LLM_CREATIVE_MODEL=gpt-4o

# Modele Anthropic (backup / alternatywa)
LLM_PRIMARY_ANTHROPIC_MODEL=claude-sonnet-4-6
LLM_FAST_ANTHROPIC_MODEL=claude-haiku-4-5-20251001
LLM_CREATIVE_ANTHROPIC_MODEL=claude-sonnet-4-6

# ----- OpenAI API -----
OPENAI_API_KEY=

# ----- Anthropic API (opcjonalne — fallback lub główny) -----
ANTHROPIC_API_KEY=

# ----- ElevenLabs TTS (premium audio — opcjonalne) -----
# Uzyskaj klucz: https://elevenlabs.io
ELEVENLABS_API_KEY=
# ID głosów — znajdź w Voice Library ElevenLabs:
ELEVENLABS_VOICE_NARRATOR_MALE=          # np. pNInz6obpgDQGcFmaJgB (Adam)
ELEVENLABS_VOICE_NARRATOR_FEMALE=        # np. EXAVITQu4vr4xnSDxMaL (Bella)
ELEVENLABS_VOICE_CONTEMPLATIVE=          # np. VR6AewLTigWG4xSOukaG (Arnold)
ELEVENLABS_VOICE_SACRED=                 # np. ErXwobaYiN019PkySvjV (Antoni)

# ----- Stripe (subskrypcje i płatności) -----
# Klucze testowe: https://dashboard.stripe.com/test/apikeys
# Klucze produkcyjne: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Utwórz produkty w Stripe Dashboard → Products → Add product
STRIPE_PRICE_ID_MONTHLY=price_...        # np. 39 PLN/mies.
STRIPE_PRICE_ID_YEARLY=price_...         # np. 299 PLN/rok
FRONTEND_URL=http://localhost:3000

# ----- Web Push Notifications (VAPID) -----
# Generuj parę kluczy: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIMS_EMAIL=mailto:admin@sanctanexus.org

# ----- Parametry AI (zaawansowane) -----
THEOLOGY_VALIDATION_THRESHOLD=0.85
EMOTION_DIMENSIONS=36

# ============================================================
# Feature Flags
# true  = moduł aktywny
# false = moduł wyłączony
#
# stable     → bezpieczne dla wszystkich użytkowników
# beta       → monitoruj błędy
# experimental → tylko admini / testy
# planned    → zostawić false
# ============================================================

# Moduły stable
FEATURE_LECTIO_DIVINA=true
FEATURE_BIBLE=true

# Moduły beta
FEATURE_PRAYER_JOURNAL=true
FEATURE_BREVIARY=true
FEATURE_NOTIFICATIONS=true

# Moduły experimental — włącz świadomie
FEATURE_REFLECTION_ASSISTANT=true
FEATURE_VOICE=true                       # TTS audio (wymaga ElevenLabs)
FEATURE_PRAYER_INTENTIONS=false
FEATURE_SACRAMENTAL_PREP=false

# Moduły planned — nie włączaj w produkcji
FEATURE_COMMUNITIES=false
FEATURE_RETREAT_PROGRAMS=false
FEATURE_SPIRITUAL_DASHBOARD=false
FEATURE_CONTENT_LIBRARY=false
FEATURE_EXAMINATION_OF_CONSCIENCE=false
FEATURE_DISCERNMENT_NOTEBOOK=false
