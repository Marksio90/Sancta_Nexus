# ============================================================
# Sancta Nexus - Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit the .env file to version control.
# ============================================================

# ----- Application -----
APP_NAME=Sancta Nexus
DEBUG=false

# ----- Backend -----
BACKEND_PORT=8000

# ----- Frontend -----
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# ----- PostgreSQL -----
POSTGRES_USER=sancta
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=sancta_nexus
POSTGRES_PORT=5432

# ----- Redis -----
REDIS_PORT=6379

# ----- Qdrant (Vector Database) -----
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

# ----- Neo4j (Graph Database) -----
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me-neo4j-password
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

# ----- OpenAI API -----
OPENAI_API_KEY=
LLM_PROVIDER=openai

# ----- Anthropic API (optional) -----
ANTHROPIC_API_KEY=

# ----- Authentication -----
SECRET_KEY=change-me-to-a-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ============================================================
# Feature Flags
# Kontroluj, które moduły są dostępne dla użytkowników.
# true  = moduł aktywny
# false = moduł wyłączony (niewidoczny w UI)
#
# Zasada:
#   stable     → może być true dla wszystkich użytkowników
#   beta       → może być true, monitoruj błędy
#   experimental → true tylko dla adminów / testów
#   planned    → zostaw false
# ============================================================

# Moduły stable
FEATURE_LECTIO_DIVINA=true
FEATURE_BIBLE=true

# Moduły beta
FEATURE_PRAYER_JOURNAL=true
FEATURE_BREVIARY=true
FEATURE_NOTIFICATIONS=true

# Moduły experimental — włącz świadomie
FEATURE_REFLECTION_ASSISTANT=true
FEATURE_PRAYER_INTENTIONS=false
FEATURE_SACRAMENTAL_PREP=false

# Moduły planned — nie włączaj w produkcji
FEATURE_COMMUNITIES=false
FEATURE_RETREAT_PROGRAMS=false
FEATURE_SPIRITUAL_DASHBOARD=false
FEATURE_CONTENT_LIBRARY=false
FEATURE_EXAMINATION_OF_CONSCIENCE=false
FEATURE_DISCERNMENT_NOTEBOOK=false
FEATURE_VOICE=false
