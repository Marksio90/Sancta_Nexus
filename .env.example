# ============================================================
# Sancta Nexus - Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# ----- Application -----
APP_NAME=Sancta Nexus
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-random-secret-key

# ----- Backend -----
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:3000

# ----- Frontend -----
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# ----- PostgreSQL -----
POSTGRES_USER=sancta
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=sancta_nexus
POSTGRES_PORT=5432

# ----- Redis -----
REDIS_PORT=6379

# ----- Qdrant (Vector Database) -----
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

# ----- Neo4j (Graph Database) -----
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me-neo4j-password
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

# ----- OpenAI API -----
# Used for LLM-based agents (prayer generation, reflection, etc.)
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# ----- Anthropic API (optional) -----
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ----- Authentication -----
# JWT secret for token signing
JWT_SECRET_KEY=change-me-jwt-secret
JWT_ALGORITHM=HS256
# Token expiry in minutes
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ----- Logging -----
LOG_LEVEL=INFO
LOG_FORMAT=json

# ----- Sentry (optional, for error tracking) -----
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
