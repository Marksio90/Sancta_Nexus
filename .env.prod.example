# ============================================================
# Sancta Nexus — Production Environment Variables
# Skopiuj do .env.prod i uzupełnij WSZYSTKIE wartości.
# NIGDY nie commituj .env.prod do repozytorium.
#
# Uruchamianie:
#   docker compose -f docker-compose.prod.yml up -d
# ============================================================

# ----- Domena -----
DOMAIN=sanctanexus.org
CERTBOT_EMAIL=admin@sanctanexus.org

# ----- Klucz tajny aplikacji (min. 64 losowe znaki) -----
# Generuj: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=CHANGE_ME_GENERATE_WITH_SECRETS_TOKEN_HEX_64

# ----- PostgreSQL -----
POSTGRES_USER=sancta
POSTGRES_PASSWORD=CHANGE_ME_STRONG_POSTGRES_PASSWORD
POSTGRES_DB=sancta_nexus

# ----- Redis -----
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD

# ----- JWT / Auth -----
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ----- CORS -----
# Oddzielone przecinkami, bez spacji
ALLOWED_ORIGINS=https://sanctanexus.org,https://www.sanctanexus.org

# ----- Rate limiting -----
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW=60

# ----- Qdrant (Vector DB — wymagane tylko z profilem qdrant) -----
QDRANT_API_KEY=CHANGE_ME_QDRANT_API_KEY

# ----- Neo4j (Knowledge Graph — wymagane tylko z profilem neo4j) -----
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME_STRONG_NEO4J_PASSWORD

# ----- Stripe (Płatności) -----
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
STRIPE_PRICE_ID_MONTHLY=price_CHANGE_ME_MONTHLY
STRIPE_PRICE_ID_YEARLY=price_CHANGE_ME_YEARLY

# ----- OpenAI (Wymagane dla AI) -----
OPENAI_API_KEY=sk-CHANGE_ME

# ----- Anthropic (opcjonalne — model claude-*) -----
# ANTHROPIC_API_KEY=sk-ant-CHANGE_ME

# ----- ElevenLabs (TTS — wymagane dla głosu) -----
ELEVENLABS_API_KEY=CHANGE_ME

# ----- VAPID (Push notifications) -----
# Generuj: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=CHANGE_ME_VAPID_PUBLIC_KEY
VAPID_PRIVATE_KEY=CHANGE_ME_VAPID_PRIVATE_KEY
VAPID_CLAIMS_EMAIL=mailto:admin@sanctanexus.org

# ----- Frontend (Next.js) -----
NEXT_PUBLIC_API_URL=https://sanctanexus.org
NEXT_PUBLIC_VAPID_PUBLIC_KEY=CHANGE_ME_VAPID_PUBLIC_KEY

# ----- Feature Flags (produkcja — włącz świadomie) -----
FEATURE_LECTIO_DIVINA=true
FEATURE_BIBLE=true
FEATURE_PRAYER_JOURNAL=true
FEATURE_BREVIARY=true
FEATURE_NOTIFICATIONS=true
FEATURE_REFLECTION_ASSISTANT=true
FEATURE_VOICE=true
FEATURE_PRAYER_INTENTIONS=true
FEATURE_SACRAMENTAL_PREP=true
FEATURE_COMMUNITIES=false
FEATURE_RETREAT_PROGRAMS=false
FEATURE_SPIRITUAL_DASHBOARD=false

# ============================================================
# PIERWSZE URUCHOMIENIE — SSL
#
# 1. Uruchom nginx (bez SSL) i certbot, by uzyskać certyfikat:
#    docker compose -f docker-compose.prod.yml --profile certbot up certbot
#
# 2. Po sukcesie uruchom cały stack:
#    docker compose -f docker-compose.prod.yml up -d
#
# 3. Odnawianie certyfikatu (dodaj do crontab):
#    0 3 * * * docker compose -f /srv/sancta-nexus/docker-compose.prod.yml \
#              --profile certbot run --rm certbot renew && \
#              docker compose -f /srv/sancta-nexus/docker-compose.prod.yml \
#              exec nginx nginx -s reload
# ============================================================
