*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
.eggs/
.venv/
venv/
env/
*.whl
.mypy_cache/
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/

# ----- Node.js -----
node_modules/
.next/
out/
.nuxt/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ----- Environment -----
.env
.env.local
.env.*.local

# ----- Docker -----
volumes/

# ----- IDE -----
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/

# ----- OS -----
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ----- Data / Databases -----
*.db
*.sqlite
*.sqlite3

# ----- Secrets & Keys -----
*.pem
*.key
*.crt
*.p12

# ----- Misc -----
*.log
tmp/
temp/
.cache/
